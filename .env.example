# hq-x — env vars consumed by app.config.Settings.
# In Doppler these live in the hq-x project (configs: dev, stg, prd). This
# file documents names + defaults for local-only debug runs that don't go
# through `doppler run`.

# ── Tier-1 boot-required ─────────────────────────────────────────────
HQX_DB_URL_POOLED=
HQX_DB_URL_DIRECT=
HQX_SUPABASE_URL=
HQX_SUPABASE_SERVICE_ROLE_KEY=
HQX_SUPABASE_PUBLISHABLE_KEY=
HQX_SUPABASE_PROJECT_REF=
APP_ENV=dev
LOG_LEVEL=INFO

# ── Webhook secrets (existing) ───────────────────────────────────────
CAL_WEBHOOK_SECRET=
EMAILBISON_WEBHOOK_PATH_TOKEN=
EMAILBISON_WEBHOOK_ALLOWED_ORIGINS=app.emailbison.com,emailbison.com

# ── Trigger.dev ──────────────────────────────────────────────────────
TRIGGER_SHARED_SECRET=

# ── Lob (direct mail) ────────────────────────────────────────────────
# Single global API key. NOT per-org. Copy the working OEX value into
# Doppler hq-x/{dev,stg,prd} as LOB_API_KEY.
LOB_API_KEY=

# Lob webhook secret (HMAC-SHA256). Required when
# LOB_WEBHOOK_SIGNATURE_MODE=enforce (which prd insists on at boot).
LOB_WEBHOOK_SECRET=

# enforce | permissive_audit | disabled. permissive_audit logs failures but
# accepts the event (used in dev/stg). enforce is required in prd; the app
# refuses to boot if APP_ENV=prd and mode is anything else.
LOB_WEBHOOK_SIGNATURE_MODE=permissive_audit
LOB_WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300
LOB_WEBHOOK_SCHEMA_VERSIONS=v1

# SLO thresholds (rates; 0.01 = 1%). Negative disables the check.
LOB_SLO_SIGNATURE_REJECT_RATE_THRESHOLD=0.01
LOB_SLO_DEAD_LETTER_RATE_THRESHOLD=0.01
LOB_SLO_REPLAY_FAILURE_RATE_THRESHOLD=0.05
LOB_SLO_PROJECTION_FAILURE_RATE_THRESHOLD=0.01
LOB_SLO_DUPLICATE_IGNORE_RATE_THRESHOLD=0.2
